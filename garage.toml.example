metadata_dir = "/var/lib/garage/meta"
data_dir     = "/var/lib/garage/data"

replication_factor = 1

# IMPORTANT: Generate a real secret before first use!
#   openssl rand -hex 32
# Never commit garage.toml with the actual secret.
rpc_secret = "REPLACE_ME_WITH_openssl_rand_hex_32"

rpc_bind_addr = "0.0.0.0:3901"

[s3_api]
s3_region     = "garage"
api_bind_addr = "0.0.0.0:3900"

[admin]
api_bind_addr = "0.0.0.0:3902"
