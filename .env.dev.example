# GP-200 Editor — Local Development Environment
# Copy to .env.dev before first docker compose up:
#   cp .env.dev.example .env.dev

# ── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3320
NEXT_PUBLIC_APP_URL=http://localhost:3320

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=gp200dev
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=gp200dev
DATABASE_URL=postgresql://gp200dev:CHANGE_ME@postgres:5432/gp200dev

# ── Garage S3 Object Storage ────────────────────────────────────────────────
# Run: bash scripts/garage-init.sh  (after first docker compose up)
GARAGE_ENDPOINT=http://garage:3900
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=
GARAGE_BUCKET=avatars
GARAGE_PRESET_BUCKET=presets

# ── Email (Mailhog — no auth needed in dev) ──────────────────────────────────
EMAIL_FROM=noreply@gp200editor.local
EMAIL_SMTP_HOST=mailhog
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
