# GP-200 Editor — Production Environment
# Copy to .env.prod and fill in values before first deploy

# ── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3320
NEXT_PUBLIC_APP_URL=https://gp200.example.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=gp200
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gp200
DATABASE_URL=postgresql://gp200:CHANGE_ME_STRONG_PASSWORD@postgres:5432/gp200

# ── Garage S3 Object Storage ────────────────────────────────────────────────
# These are set automatically by scripts/deploy.sh on first run.
# If deploying manually, run scripts/garage-init.sh and paste the output here.
GARAGE_ENDPOINT=http://garage:3900
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=
GARAGE_BUCKET=avatars
GARAGE_PRESET_BUCKET=presets

# ── Anti-Spam (Cloudflare Turnstile) ────────────────────────────────────────
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
# Registration is BLOCKED in production if these are not set!
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Email (SMTP) ────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@gp200.example.com
EMAIL_SMTP_HOST=mailhog
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
# For real email (e.g. via Mailgun, SendGrid, etc.):
# EMAIL_SMTP_HOST=smtp.mailgun.org
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=postmaster@mg.example.com
# EMAIL_SMTP_PASS=your-api-key
